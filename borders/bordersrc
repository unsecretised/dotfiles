#!/bin/bash

BG_BASE="0x1f1f28"
BG_SURFACE="0x2a2a37"
BG_OVERLAY="0x363646"

WAVE_BLUE="0x7e9cd8"
SPRING_VIOLET="0x957fb8"
AUTUMN_RED="0xc34043"
WAVE_AQUA="0x7fb4ca"
SPRING_GREEN="0x98bb6c"
AUTUMN_YELLOW="0xdca561"
SAKURA_PINK="0xd27e99"
OLD_WHITE="0xdcd7ba"

FG_PRIMARY="0xdcd7ba"
FG_SECONDARY="0xc8c093"
FG_DIM="0x727169"

WALL_BASE="0x2d343f"
WALL_MUTED="0x3d4a5c"
WALL_ACCENT="0x4a5f7a"

# Helper: convert 0xRRGGBB → 0xAARRGGBB with given alpha byte
# Usage: with_alpha <0xRRGGBB> <AA>
# e.g.  with_alpha "$SPRING_VIOLET" "ff"
with_alpha() {
  echo "0x${2}${1:2}"
}

options=(
  style=round
  width=3.0
  hidpi=on
  active_color=$(with_alpha "$SPRING_VIOLET" "ff")
  inactive_color=$(with_alpha "$BG_BASE" "aa")
  blacklist="Sxitch","sxitch"
)

borders "${options[@]}"
